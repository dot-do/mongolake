{
  "description": "replaceOne",
  "schemaVersion": "1.0",
  "createEntities": [
    {
      "client": {
        "id": "client0"
      }
    },
    {
      "database": {
        "id": "database0",
        "client": "client0",
        "databaseName": "crud-v1"
      }
    },
    {
      "collection": {
        "id": "collection0",
        "database": "database0",
        "collectionName": "coll"
      }
    }
  ],
  "initialData": [
    {
      "collectionName": "coll",
      "databaseName": "crud-v1",
      "documents": [
        {
          "_id": 1,
          "x": 11
        },
        {
          "_id": 2,
          "x": 22
        }
      ]
    }
  ],
  "tests": [
    {
      "description": "ReplaceOne when one document matches",
      "operations": [
        {
          "object": "collection0",
          "name": "replaceOne",
          "arguments": {
            "filter": {
              "_id": 1
            },
            "replacement": {
              "y": 111
            }
          },
          "expectResult": {
            "matchedCount": 1,
            "modifiedCount": 1,
            "upsertedCount": 0
          }
        }
      ],
      "outcome": [
        {
          "collectionName": "coll",
          "databaseName": "crud-v1",
          "documents": [
            {
              "_id": 1,
              "y": 111
            },
            {
              "_id": 2,
              "x": 22
            }
          ]
        }
      ]
    },
    {
      "description": "ReplaceOne when no documents match",
      "operations": [
        {
          "object": "collection0",
          "name": "replaceOne",
          "arguments": {
            "filter": {
              "_id": 99
            },
            "replacement": {
              "y": 999
            }
          },
          "expectResult": {
            "matchedCount": 0,
            "modifiedCount": 0,
            "upsertedCount": 0
          }
        }
      ],
      "outcome": [
        {
          "collectionName": "coll",
          "databaseName": "crud-v1",
          "documents": [
            {
              "_id": 1,
              "x": 11
            },
            {
              "_id": 2,
              "x": 22
            }
          ]
        }
      ]
    },
    {
      "description": "ReplaceOne with upsert when no documents match",
      "operations": [
        {
          "object": "collection0",
          "name": "replaceOne",
          "arguments": {
            "filter": {
              "_id": 3
            },
            "replacement": {
              "_id": 3,
              "y": 333
            },
            "upsert": true
          },
          "expectResult": {
            "matchedCount": 0,
            "modifiedCount": 0,
            "upsertedCount": 1,
            "upsertedId": 3
          }
        }
      ],
      "outcome": [
        {
          "collectionName": "coll",
          "databaseName": "crud-v1",
          "documents": [
            {
              "_id": 1,
              "x": 11
            },
            {
              "_id": 2,
              "x": 22
            },
            {
              "_id": 3,
              "y": 333
            }
          ]
        }
      ]
    }
  ]
}
