{
  "name": "mongolake",
  "version": "0.1.0",
  "description": "MongoDB re-imagined for the lakehouse era",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    },
    "./do": {
      "types": "./dist/do/index.d.ts",
      "import": "./dist/do/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./parquet": {
      "types": "./dist/parquet/index.d.ts",
      "import": "./dist/parquet/index.js"
    },
    "./mongoose": {
      "types": "./dist/mongoose/index.d.ts",
      "import": "./dist/mongoose/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./wire-protocol": {
      "types": "./dist/wire-protocol/index.d.ts",
      "import": "./dist/wire-protocol/index.js"
    },
    "./index": {
      "types": "./dist/index/index.d.ts",
      "import": "./dist/index/index.js"
    },
    "./storage/s3": {
      "types": "./dist/storage/s3/index.d.ts",
      "import": "./dist/storage/s3/index.js"
    },
    "./metrics": {
      "types": "./dist/metrics/index.d.ts",
      "import": "./dist/metrics/index.js"
    },
    "./transaction": {
      "types": "./dist/transaction/index.d.ts",
      "import": "./dist/transaction/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js"
    }
  },
  "bin": {
    "mongolake": "./dist/cli/index.js",
    "mongolake-server": "./dist/wire-protocol/tcp-server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "build:cli": "bun build src/cli/index.ts --compile --outfile dist/mongolake",
    "dev": "tsc --watch",
    "start": "node dist/wire-protocol/tcp-server.js",
    "start:dev": "tsx src/wire-protocol/tcp-server.ts",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:load": "vitest run --config vitest.load.config.ts",
    "test:compat": "vitest run --config vitest.compat.config.ts",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:scale": "vitest run --config vitest.scale.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "test:mutation": "stryker run",
    "lint": "eslint src",
    "benchmark": "npx tsx tests/benchmark/run-all.ts",
    "benchmark:insert": "npx tsx tests/benchmark/insert-benchmark.ts",
    "benchmark:find": "npx tsx tests/benchmark/find-benchmark.ts",
    "benchmark:parquet": "npx tsx tests/benchmark/parquet-benchmark.ts",
    "benchmark:index": "npx tsx tests/benchmark/index-benchmark.ts",
    "benchmark:vitest": "vitest bench --config vitest.bench.config.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mongodb",
    "database",
    "lakehouse",
    "parquet",
    "iceberg",
    "cloudflare",
    "workers",
    "r2",
    "duckdb"
  ],
  "author": "dotdo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-do/mongolake"
  },
  "homepage": "https://mongolake.com",
  "dependencies": {
    "@dotdo/cli": "^0.2.5",
    "@dotdo/iceberg": "^0.1.0",
    "hyparquet": "^1.7.2",
    "hyparquet-writer": "^0.3.0",
    "oauth.do": "^0.2.0",
    "rpc.do": "^0.2.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.8",
    "@cloudflare/workers-types": "^4.20240117.0",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@types/node": "^20.10.0",
    "@vitest/runner": "^3.2.4",
    "@vitest/snapshot": "^3.2.4",
    "fast-check": "^4.5.3",
    "husky": "^9.0.0",
    "miniflare": "^4.20260128.0",
    "mongodb": "^6.3.0",
    "mongodb-memory-server": "^11.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4",
    "wrangler": "^3.22.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
